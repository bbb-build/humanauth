{
  "name": "humanauth-sdk",
  "version": "0.1.2",
  "description": "HumanAuth SDK — World ID verification as a service",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "world-id",
    "authentication",
    "humanauth",
    "proof-of-humanity",
    "world-chain"
  ],
  "author": "BBB&Company",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbb-build/humanauth"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@worldcoin/idkit": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@worldcoin/idkit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
