# Copy to .env.local and fill in
# 1. Visit https://humanauth.vercel.app/dashboard/oauth and create a Client
# 2. redirect_uri must include http://localhost:3000/oauth/callback
# 3. Paste client_id below

NEXT_PUBLIC_HUMANAUTH_CLIENT_ID=ha_oauth_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_HUMANAUTH_API_URL=https://humanauth.vercel.app
NEXT_PUBLIC_HUMANAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
